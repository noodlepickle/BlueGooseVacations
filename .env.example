POSTGRES_PASSWORD=changeme

# Listing sources
RAPIDAPI_KEY=              # enables Zillow + Realtor.com

# Email via Resend
RESEND_API_KEY=            # re_xxxxxxxxxxxx
DIGEST_FROM=               # screener@yourdomain.com
DIGEST_TO=                 # comma-separated recipient list

# Notion (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# AirDNA (optional — activates automatically when set)
AIRDNA_API_KEY=

# Scheduler cron (default: 6am daily)
SCREENER_CRON=0 6 * * *
